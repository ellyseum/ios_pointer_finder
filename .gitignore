# Model weights — distributed via Hugging Face Hub + GitHub Releases, never git.
*.pt
*.pth
*.safetensors
*.onnx
*.mlpackage
*.mlmodel

# Sidecar metadata that's emitted alongside .pt during training; the public
# config.json shipped with the canonical weights goes through Releases.
pointer_model_*.config.json

# Image assets — backgrounds, real test frames, generated dataset, scratch images
*.png
*.jpg
*.jpeg

# Whitelist: the captured iOS pointer sprite — runtime dependency of the
# synthesizer (loaded by synthesize.py:_load_real_sprite). Ships with the
# repo so users don't need an external download to regenerate the dataset.
!sprites/at_dot.png

# Generated training data — re-derive from backgrounds_kept/ via synthesize.py
dataset/
backgrounds/
backgrounds_kept
backgrounds_kept/
real_pointer_test
real_pointer_test/

# Python
__pycache__/
*.pyc
*.pyo

# Build / install artifacts
dist/
build/
*.egg-info/
.eggs/

# Virtualenvs
.venv/
venv/
.env

# Test / lint caches
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage*

# Editor / OS
.vscode/
.idea/
.DS_Store

# Local scratch
*.swp
*.tmp

# Renamed v0.3 dataset (kept for ablation; do not commit images)
dataset_v*/

# Internal retrospective notes — not part of the OSS distribution
reports/
